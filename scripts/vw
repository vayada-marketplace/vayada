#!/usr/bin/env bash
# vw — vayada worktree helper
# Subcommands: new, done, list, sync
set -euo pipefail

MAIN_REPO="/Users/flamurmaliqi/git/vayada"
WORKTREE_PARENT="/Users/flamurmaliqi/git"
VW_AGENT_CMD="${VW_AGENT_CMD:-claude --permission-mode auto}"
VW_AGENT_NAME="${VW_AGENT_NAME:-${VW_AGENT_CMD%% *}}"
VW_TERMINAL_APP="${VW_TERMINAL_APP:-Warp}"

agent_auto_disabled() {
  [ "${VW_NO_AUTO_AGENT:-${VW_NO_AUTO_CLAUDE:-0}}" = "1" ]
}

agent_launch_command() {
  local worktree="$1"
  local prompt="$2"
  local quoted_worktree quoted_prompt agent_cmd
  printf -v quoted_worktree "%q" "$worktree"
  printf -v quoted_prompt "%q" "$prompt"
  if [[ "$VW_AGENT_CMD" == *"{prompt}"* ]]; then
    agent_cmd="${VW_AGENT_CMD//\{prompt\}/$quoted_prompt}"
  else
    agent_cmd="$VW_AGENT_CMD $quoted_prompt"
  fi
  printf "cd %s && %s" "$quoted_worktree" "$agent_cmd"
}

applescript_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf "%s" "$value"
}

open_agent_tab() {
  local worktree="$1"
  local prompt="$2"
  local command
  command="$(agent_launch_command "$worktree" "$prompt")"
  command="$(applescript_escape "$command")"

  /usr/bin/osascript <<APPLESCRIPT 2>/dev/null || true
tell application "$VW_TERMINAL_APP" to activate
delay 0.4
tell application "System Events"
    keystroke "t" using command down
    delay 0.5
    keystroke "$command"
    keystroke return
end tell
APPLESCRIPT
}

normalize_ticket() {
  # Pure digits → prefix with VAY-. Otherwise pass through unchanged.
  if [[ "$1" =~ ^[0-9]+$ ]]; then
    echo "VAY-$1"
  else
    echo "$1"
  fi
}

usage() {
  cat <<HELP
vw — vayada worktree helper

  vw new <TICKET> [--install]   Create worktree on branch <TICKET> off main,
                                init submodules, copy .env files, open a new
                                Warp tab running the configured agent.
                                --install also runs deps install in submodules.

  vw done <TICKET>              Remove the worktree and delete the local branch.

  vw list                       Show all active worktrees.

  vw sync                       Pull main repo, rebase every worktree branch
                                on origin/main, and re-init submodules in all
                                worktrees (main repo included).

  vw ship-ready                 Scan all worktrees; for each whose branch tip
                                is already in origin/main (the agent shipped),
                                run vw done on it. Run vw sync at the end.

  vw ship-all                   Ship every worktree sequentially: commit any
                                uncommitted submodule work on a feature branch,
                                merge each submodule's feature into its main and
                                push, bump submodule pointers in the parent, and
                                push the parent branch to origin/main. Then run
                                ship-ready to clean up.

Agent environment:
  VW_AGENT_CMD                  Agent command to launch with the prompt appended.
                                Use {prompt} to place the prompt manually.
                                Default: claude --permission-mode auto
                                Example: VW_AGENT_CMD=codex vw new VAY-123
  VW_AGENT_NAME                 Display name for log output. Default: first word
                                of VW_AGENT_CMD.
  VW_TERMINAL_APP               macOS terminal app to open. Default: Warp.
  VW_NO_AUTO_AGENT=1            Disable automatic agent launch on failures.
                                VW_NO_AUTO_CLAUDE=1 is still supported.
HELP
}

cmd_new() {
  local ticket="${1:-}"
  local do_install=0
  shift || true
  while [ $# -gt 0 ]; do
    case "$1" in
      --install) do_install=1 ;;
      *) echo "Unknown flag: $1"; exit 1 ;;
    esac
    shift
  done

  [ -z "$ticket" ] && { echo "Usage: vw new <TICKET|number> [--install]"; exit 1; }
  ticket="$(normalize_ticket "$ticket")"

  local worktree="$WORKTREE_PARENT/vayada-$ticket"
  local branch="$ticket"

  if [ -e "$worktree" ]; then
    echo "✗ Worktree already exists: $worktree"
    exit 1
  fi

  cd "$MAIN_REPO"

  local remote
  remote="$(git config branch.main.remote 2>/dev/null || git remote | head -n1)"
  [ -z "$remote" ] && { echo "✗ No git remote configured on $MAIN_REPO"; exit 1; }

  echo "→ Creating worktree at $worktree on branch $branch (off $remote/main)"
  git fetch "$remote" main --quiet
  git worktree add -b "$branch" "$worktree" "$remote/main"

  echo "→ Initializing submodules"
  cd "$worktree"
  git submodule update --init --recursive --quiet

  echo "→ Copying .env files from main repo"
  while IFS= read -r src; do
    local rel="${src#$MAIN_REPO/}"
    local dst="$worktree/$rel"
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "   $rel"
  done < <(find "$MAIN_REPO" \
              \( -name ".env" -o -name ".env.local" \) \
              -not -path "*/node_modules/*" \
              -not -path "*/.git/*" \
              -not -name "*.example" \
              2>/dev/null)

  if [ "$do_install" -eq 1 ]; then
    echo "→ Installing deps in submodules (this may take a while)"
    while IFS= read -r pkg; do
      local dir="$(dirname "$pkg")"
      echo "   npm install in ${dir#$worktree/}"
      ( cd "$dir" && npm install --silent ) || echo "     (failed, continue)"
    done < <(find "$worktree" -maxdepth 4 -name "package.json" -not -path "*/node_modules/*" 2>/dev/null)

    while IFS= read -r req; do
      local dir="$(dirname "$req")"
      echo "   pip install in ${dir#$worktree/}"
      ( cd "$dir" && pip install -q -r requirements.txt ) || echo "     (failed, continue)"
    done < <(find "$worktree" -maxdepth 4 -name "requirements.txt" -not -path "*/node_modules/*" 2>/dev/null)
  fi

  echo "→ Opening new $VW_TERMINAL_APP tab with $VW_AGENT_NAME"
  local prompt="You are in a fresh git worktree for Linear ticket $ticket, on branch $ticket. Work in two phases:

PHASE 1 — PLAN. Use the linear MCP server to fetch ticket $ticket, then move the ticket to \"In Progress\" via the linear MCP server. Propose a concise implementation plan and wait for my approval.

PHASE 2 — IMPLEMENT AND COMMIT. After I approve, implement the change. Install deps in any submodule you touch. Run tests where they exist. Then commit everything locally — do NOT merge to main, do NOT push, do NOT open PRs. \`vw ship-all\` will run the merge-to-main + push dance later.

For each submodule with changes:
  1. Create or checkout a feature branch named $ticket inside the submodule.
  2. Commit with a descriptive message (what changed and why, not just \"ship\").

In the parent worktree:
  3. git add the bumped submodule paths.
  4. git commit -m \"Bump <submodule>: <summary> ($ticket)\" with a real summary.

Stop after committing. Report the local commit SHAs and wait."

  open_agent_tab "$worktree" "$prompt"

  echo "✓ Worktree ready: $worktree"
}

cmd_done() {
  local ticket="${1:-}"
  [ -z "$ticket" ] && { echo "Usage: vw done <TICKET|number>"; exit 1; }
  ticket="$(normalize_ticket "$ticket")"

  local worktree="$WORKTREE_PARENT/vayada-$ticket"

  cd "$MAIN_REPO"
  if [ ! -e "$worktree" ]; then
    echo "✗ No worktree at $worktree"
    exit 1
  fi

  echo "→ Deinitializing submodules in worktree"
  ( cd "$worktree" && git submodule deinit --all -f --quiet ) || true

  echo "→ Removing worktree $worktree"
  git worktree remove --force "$worktree"

  if git show-ref --verify --quiet "refs/heads/$ticket"; then
    echo "→ Deleting branch $ticket"
    git branch -D "$ticket"
  fi

  echo "✓ Done"
}

cmd_list() {
  cd "$MAIN_REPO"
  git worktree list
}

cmd_sync() {
  cd "$MAIN_REPO"

  local remote
  remote="$(git config branch.main.remote 2>/dev/null || git remote | head -n1)"
  [ -z "$remote" ] && { echo "✗ No git remote configured on $MAIN_REPO"; exit 1; }

  echo "→ Fetching $remote/main"
  git fetch "$remote" main --quiet

  # Sync the main repo too: ship-all pushes from worktrees advance
  # $remote/main, so the main repo's local branch and submodule HEADs drift
  # behind unless we pull and re-checkout submodule SHAs explicitly.
  local main_branch
  main_branch="$(git -C "$MAIN_REPO" branch --show-current)"
  if [ "$main_branch" != "main" ]; then
    echo "→ Skipping main repo ($main_branch checked out, not main)"
  else
    # Snap submodules to currently-recorded SHAs first so autostash doesn't
    # re-apply stale pointers on top of the new parent commit.
    git -C "$MAIN_REPO" submodule update --init --recursive --quiet 2>/dev/null || true

    if ! git -C "$MAIN_REPO" merge-base --is-ancestor "$remote/main" main 2>/dev/null; then
      echo "→ Pulling main repo (rebase --autostash)"
      if ! git -C "$MAIN_REPO" -c rebase.autostash=true pull --rebase "$remote" main --quiet; then
        echo "   pull --rebase failed — resolve manually in $MAIN_REPO"
        launch_agent_to_resolve "$MAIN_REPO" "vw sync: git pull --rebase on the main vayada repo failed. Investigate (likely a local commit, dirty state, or submodule pointer conflict) and resolve so the main repo can fast-forward to $remote/main."
      fi
    fi

    if ! git -C "$MAIN_REPO" submodule update --init --recursive --quiet 2>/dev/null; then
      echo "   submodule update failed in main repo — resolve manually"
    fi
  fi

  while IFS= read -r wt; do
    [ "$wt" = "$MAIN_REPO" ] && continue

    local wt_branch
    wt_branch="$(git -C "$wt" branch --show-current)"

    if [ -z "$wt_branch" ]; then
      echo "→ Skipping $wt (detached HEAD or mid-rebase)"
      continue
    fi

    if git merge-base --is-ancestor "$wt_branch" "$remote/main" 2>/dev/null; then
      echo "→ Skipping $wt ($wt_branch already in $remote/main)"
      continue
    fi

    echo "→ Syncing $wt ($wt_branch)"
    if ! rebase_with_submodule_autoresolve "$wt" "$remote/main" >/dev/null 2>&1; then
      echo "   rebase failed — leaving clean state"
      echo "   resolve manually in $wt, or run: vw done $wt_branch"
      launch_agent_to_resolve "$wt" "vw sync: rebasing $wt_branch onto $remote/main failed. The worktree was reset to a clean pre-rebase state by rebase --abort. Investigate why the rebase fails (likely submodule pointer divergence) and either complete it manually, or, if this branch is already obsolete, run vw done $wt_branch."
      continue
    fi

    if ! git -C "$wt" submodule update --init --recursive --quiet 2>/dev/null; then
      echo "   submodule update failed (likely dirty submodule) — resolve in $wt"
    fi
  done < <(git worktree list --porcelain | awk '/^worktree / {print $2}')

  echo "✓ Synced"
}

cmd_ship_ready() {
  cd "$MAIN_REPO"

  local remote
  remote="$(git config branch.main.remote 2>/dev/null || git remote | head -n1)"
  [ -z "$remote" ] && { echo "✗ No git remote configured on $MAIN_REPO"; exit 1; }

  echo "→ Fetching $remote/main"
  git fetch "$remote" main --quiet

  local cleaned=0
  while IFS= read -r wt; do
    [ "$wt" = "$MAIN_REPO" ] && continue

    local wt_branch
    wt_branch="$(git -C "$wt" branch --show-current)"
    if [ -z "$wt_branch" ]; then
      echo "→ Skipping $wt (detached HEAD)"
      continue
    fi

    if ! git merge-base --is-ancestor "$wt_branch" "$remote/main" 2>/dev/null; then
      echo "→ Skipping $wt_branch (not yet in $remote/main)"
      continue
    fi

    if [ -n "$(git -C "$wt" status --porcelain)" ]; then
      echo "→ Skipping $wt_branch (uncommitted changes — finish or revert first)"
      continue
    fi

    echo "→ Cleaning up $wt_branch"
    if cmd_done "$wt_branch"; then
      cleaned=$((cleaned + 1))
    else
      echo "   ✗ vw done failed for $wt_branch — leaving in place"
    fi
  done < <(git worktree list --porcelain | awk '/^worktree / {print $2}')

  if [ "$cleaned" -gt 0 ]; then
    echo
    cmd_sync
  else
    echo "✓ Nothing ready to clean up"
  fi
}

# Try to auto-resolve submodule pointer conflicts in the index. For each
# conflicted submodule, pick a SHA that is a descendant of both the ours and
# theirs sides — first via direct ancestor relation, then via the submodule's
# remote/main (which contains the just-shipped merge commit).
# Returns 0 only when zero conflicts remain in the index.
auto_resolve_submodule_conflicts() {
  local wt="$1"
  local paths
  paths="$(git -C "$wt" ls-files -u | awk -F'\t' '{print $2}' | sort -u)"
  [ -z "$paths" ] && return 0

  while IFS= read -r p; do
    [ -z "$p" ] && continue

    # Skip non-submodule conflicts (different mode in any stage).
    if git -C "$wt" ls-files -u -- "$p" | awk '$1 != "160000"' | grep -q .; then
      continue
    fi

    local sha_ours sha_theirs
    sha_ours="$(git -C "$wt" ls-files -u -- "$p" | awk '$3 == 2 {print $2}')"
    sha_theirs="$(git -C "$wt" ls-files -u -- "$p" | awk '$3 == 3 {print $2}')"
    if [ -z "$sha_ours" ] || [ -z "$sha_theirs" ]; then continue; fi

    local pick=""
    if git -C "$wt/$p" merge-base --is-ancestor "$sha_ours" "$sha_theirs" 2>/dev/null; then
      pick="$sha_theirs"
    elif git -C "$wt/$p" merge-base --is-ancestor "$sha_theirs" "$sha_ours" 2>/dev/null; then
      pick="$sha_ours"
    else
      local sub_remote sub_main
      sub_remote="$(git -C "$wt/$p" config branch.main.remote 2>/dev/null || git -C "$wt/$p" remote | head -n1)"
      [ -n "$sub_remote" ] && git -C "$wt/$p" fetch "$sub_remote" main --quiet 2>/dev/null || true
      sub_main="$(git -C "$wt/$p" rev-parse "$sub_remote/main" 2>/dev/null || echo '')"
      if [ -n "$sub_main" ] \
         && git -C "$wt/$p" merge-base --is-ancestor "$sha_ours" "$sub_main" 2>/dev/null \
         && git -C "$wt/$p" merge-base --is-ancestor "$sha_theirs" "$sub_main" 2>/dev/null; then
        pick="$sub_main"
      fi
    fi

    [ -z "$pick" ] && continue
    git -C "$wt" update-index --cacheinfo "160000,$pick,$p" 2>/dev/null || true
  done <<< "$paths"

  [ -z "$(git -C "$wt" ls-files -u)" ]
}

# Rebase $wt onto $base, auto-resolving submodule pointer conflicts where
# possible. Returns 0 on success; aborts and returns 1 on unresolvable
# conflicts. Drops empty commits (e.g. a parent "Bump submodules" commit
# whose pointer change is now redundant after auto-resolution).
rebase_with_submodule_autoresolve() {
  local wt="$1" base="$2"

  if GIT_EDITOR=true git -C "$wt" rebase --empty=drop "$base" --quiet 2>/dev/null; then
    return 0
  fi

  local i max=20
  for (( i=0; i<max; i++ )); do
    local rebase_dir
    rebase_dir="$(git -C "$wt" rev-parse --git-path rebase-merge 2>/dev/null)"
    [ ! -d "$rebase_dir" ] && rebase_dir="$(git -C "$wt" rev-parse --git-path rebase-apply 2>/dev/null)"
    [ ! -d "$rebase_dir" ] && return 0  # Rebase finished

    if ! auto_resolve_submodule_conflicts "$wt"; then
      git -C "$wt" rebase --abort 2>/dev/null || true
      return 1
    fi

    if GIT_EDITOR=true git -C "$wt" rebase --continue --quiet 2>/dev/null; then
      continue
    fi

    # --continue failed. If no conflicts remain, current commit is empty
    # (changes folded into the auto-resolution); skip it.
    if [ -z "$(git -C "$wt" ls-files -u)" ]; then
      if ! GIT_EDITOR=true git -C "$wt" rebase --skip --quiet 2>/dev/null; then
        git -C "$wt" rebase --abort 2>/dev/null || true
        return 1
      fi
    fi
  done

  git -C "$wt" rebase --abort 2>/dev/null || true
  return 1
}

# When set by cmd_ship_all, launch_agent_to_resolve appends to this queue
# instead of opening a terminal tab per failure, so flush_agent_queue can
# dispatch all failures into a single agent session at the end of the run.
AGENT_QUEUE_WORKTREES=()
AGENT_QUEUE_CONTEXTS=()

# Open a new terminal tab cd'd into $worktree running the configured agent, with a prompt
# describing the $context of the failure so it can investigate and fix it.
# Best-effort: silently no-ops if the worktree is gone or osascript fails
# (e.g. when running headless / not on macOS / terminal app not installed).
launch_agent_to_resolve() {
  local worktree="$1"
  local context="$2"

  [ -d "$worktree" ] || return 0
  agent_auto_disabled && return 0

  if [ "${VW_BATCH_AGENT:-${VW_BATCH_CLAUDE:-0}}" = "1" ]; then
    AGENT_QUEUE_WORKTREES+=("$worktree")
    AGENT_QUEUE_CONTEXTS+=("$context")
    return 0
  fi

  local prompt="You are in a git worktree at $worktree. An automated vw workflow just failed:

$context

Investigate (git status, git log, submodule state, and $MAIN_REPO state) and fix it. Common cases for this kind of failure:
  - Submodule pointer conflict during rebase: pick the SHA whose history contains both sides (typically the submodule remote main after a just-shipped merge), then continue the rebase.
  - Real code merge conflict inside a submodule: edit the file, git add, commit inside the submodule, then continue.
  - Dirty submodule working tree blocking submodule update: commit or reset as appropriate.

After the worktree is clean and the rebase or merge is finished, re-run vw ship-all (or vw sync) from $MAIN_REPO if more work still needs shipping. Otherwise report what you did and stop."

  echo "  → launching $VW_AGENT_NAME in new $VW_TERMINAL_APP tab to resolve"
  open_agent_tab "$worktree" "$prompt"
}

# Backward-compatible name for old call sites or shell users.
launch_claude_to_resolve() {
  launch_agent_to_resolve "$@"
}

# Dispatch all queued failures into a single agent session in $MAIN_REPO.
# No-op if the queue is empty or auto agent launching is disabled.
flush_agent_queue() {
  local count=${#AGENT_QUEUE_WORKTREES[@]}
  [ "$count" -eq 0 ] && return 0
  agent_auto_disabled && return 0

  local prompt="You are at $MAIN_REPO. An automated vw ship-all run produced $count failure(s) that need manual resolution. Each failure below is independent — work through them one by one, cd-ing into the worktree listed for that entry.

"
  local i n wt ctx
  for ((i=0; i<count; i++)); do
    n=$((i+1))
    wt="${AGENT_QUEUE_WORKTREES[i]}"
    ctx="${AGENT_QUEUE_CONTEXTS[i]}"
    prompt+="── Failure $n of $count ──
Worktree: $wt
$ctx

"
  done

  prompt+="For each failure, common cases:
  - Submodule pointer conflict during rebase: pick the SHA whose history contains both sides (typically the submodule remote main after a just-shipped merge), then continue the rebase.
  - Real code merge conflict inside a submodule: edit the file, git add, commit inside the submodule, then continue.
  - Dirty submodule working tree blocking submodule update: commit or reset as appropriate.

After every worktree is clean and its rebase or merge is finished, run vw ship-all again from $MAIN_REPO to ship anything that still needs shipping. Otherwise report what you did and stop."

  echo "  → launching $VW_AGENT_NAME in new $VW_TERMINAL_APP tab to resolve $count failure(s)"
  open_agent_tab "$MAIN_REPO" "$prompt"

  AGENT_QUEUE_WORKTREES=()
  AGENT_QUEUE_CONTEXTS=()
}

# Backward-compatible name for old call sites or shell users.
flush_claude_queue() {
  flush_agent_queue "$@"
}

ship_submodule() {
  local subdir="$1" ticket="$2"

  local branch has_changes=0
  branch="$(git -C "$subdir" branch --show-current 2>/dev/null || echo '')"
  [ -n "$(git -C "$subdir" status --porcelain 2>/dev/null)" ] && has_changes=1

  # Nothing to ship: clean working tree and not on a feature branch.
  if [ "$has_changes" -eq 0 ] && { [ -z "$branch" ] || [ "$branch" = "main" ]; }; then
    return 0
  fi

  echo "  → ${subdir##*/}"

  if [ -z "$branch" ] || [ "$branch" = "main" ]; then
    git -C "$subdir" checkout -b "$ticket" --quiet 2>/dev/null \
      || git -C "$subdir" checkout "$ticket" --quiet
    branch="$ticket"
  fi

  if [ "$has_changes" -eq 1 ]; then
    git -C "$subdir" add -A
    git -C "$subdir" commit -m "$ticket: ship" --quiet
  fi

  local sub_remote
  sub_remote="$(git -C "$subdir" config branch.main.remote 2>/dev/null || git -C "$subdir" remote | head -n1)"
  [ -z "$sub_remote" ] && { echo "    ✗ no remote"; return 1; }

  git -C "$subdir" fetch "$sub_remote" main --quiet

  if git -C "$subdir" merge-base --is-ancestor "$branch" "$sub_remote/main"; then
    echo "    (already in $sub_remote/main)"
    return 0
  fi

  git -C "$subdir" checkout main --quiet
  git -C "$subdir" merge --ff-only "$sub_remote/main" --quiet 2>/dev/null || true
  if ! git -C "$subdir" merge --no-ff "$branch" -m "Merge $branch into main" --quiet; then
    git -C "$subdir" merge --abort 2>/dev/null || true
    echo "    ✗ merge conflict"
    return 1
  fi
  if ! git -C "$subdir" push "$sub_remote" main --quiet; then
    echo "    ✗ push failed"
    return 1
  fi

  echo "    ✓ pushed"
}

ship_worktree() {
  local wt="$1" ticket="$2" remote="$3"

  local subs
  subs="$(git -C "$wt" submodule --quiet foreach --recursive 'echo "$displaypath"' 2>/dev/null || true)"
  while IFS= read -r sub; do
    [ -z "$sub" ] && continue
    ship_submodule "$wt/$sub" "$ticket" || return 1
  done <<< "$subs"

  if [ -n "$(git -C "$wt" status --porcelain)" ]; then
    git -C "$wt" add -A
    git -C "$wt" commit -m "Bump submodules: $ticket" --quiet
  fi

  # Earlier worktrees may have advanced parent main; rebase if needed.
  # Auto-resolve submodule pointer conflicts: when ours/theirs diverge but
  # the just-shipped submodule main contains both, take that merge SHA.
  if ! git -C "$wt" merge-base --is-ancestor "$remote/main" "$ticket" 2>/dev/null; then
    if ! rebase_with_submodule_autoresolve "$wt" "$remote/main"; then
      echo "  ✗ parent rebase failed — resolve manually in $wt"
      launch_agent_to_resolve "$wt" "Parent worktree rebase of $ticket onto $remote/main failed during vw ship-all. Submodule pointer conflicts could not be auto-resolved. Submodule branches for this ticket were already pushed before the parent rebase was attempted, so the underlying submodule work is preserved on its remote main."
      return 1
    fi
  fi

  # Re-sync submodule HEADs to what the bumped parent commit records.
  # Without this, ship_submodule leaves submodule HEAD on the merge commit
  # on main while the parent records the feature-branch tip, so git status
  # reports the submodule as modified and ship-ready refuses to clean up.
  git -C "$wt" submodule update --init --recursive --quiet 2>/dev/null || true

  echo "  → pushing $ticket → $remote/main"
  git -C "$wt" push "$remote" "$ticket:main" --quiet || return 1
}

cmd_ship_all() {
  cd "$MAIN_REPO"

  local remote
  remote="$(git config branch.main.remote 2>/dev/null || git remote | head -n1)"
  [ -z "$remote" ] && { echo "✗ No git remote configured on $MAIN_REPO"; exit 1; }

  # Queue conflict prompts; flush_agent_queue dispatches them as one session.
  export VW_BATCH_AGENT=1

  echo "→ Fetching $remote/main"
  git fetch "$remote" main --quiet

  local shipped=0 failed=0
  while IFS= read -r wt; do
    [ "$wt" = "$MAIN_REPO" ] && continue

    local wt_branch
    wt_branch="$(git -C "$wt" branch --show-current)"
    if [ -z "$wt_branch" ]; then
      echo "→ Skipping $wt (detached HEAD)"
      continue
    fi

    if git merge-base --is-ancestor "$wt_branch" "$remote/main" 2>/dev/null; then
      echo "→ Skipping $wt_branch (already in $remote/main)"
      continue
    fi

    echo
    echo "═══ Shipping $wt_branch ═══"
    if ship_worktree "$wt" "$wt_branch" "$remote"; then
      shipped=$((shipped + 1))
    else
      failed=$((failed + 1))
      echo "✗ Failed to ship $wt_branch — leaving in place"
    fi
  done < <(git worktree list --porcelain | awk '/^worktree / {print $2}')

  echo
  echo "→ Shipped: $shipped, failed: $failed"

  flush_agent_queue

  if [ "$shipped" -gt 0 ]; then
    echo
    cmd_ship_ready
  fi
}

case "${1:-}" in
  new)  shift; cmd_new "$@" ;;
  done) shift; cmd_done "$@" ;;
  list|ls) shift; cmd_list "$@" ;;
  sync) shift; cmd_sync "$@" ;;
  ship-ready) shift; cmd_ship_ready "$@" ;;
  ship-all) shift; cmd_ship_all "$@" ;;
  -h|--help|help|"") usage ;;
  *) echo "Unknown command: $1"; echo; usage; exit 1 ;;
esac
