#!/usr/bin/env bash
#
# Wipe the local-integration sandbox: reset parent and all submodules
# to origin/main and delete any local-integration branches.
# Feature worktrees are not touched.
#
# Usage: scripts/integrate-reset

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
REPO_NAME="$(basename "$REPO_ROOT")"

if [[ "$REPO_NAME" != "vayada" ]]; then
  echo "error: must run from the main vayada worktree (~/git/vayada), not $REPO_NAME" >&2
  exit 1
fi

cd "$REPO_ROOT"

# Parent and submodules don't share a remote name (parent: "vayada",
# submodules: "origin"). Detect each from the main branch's upstream.
PARENT_REMOTE=$(git config --get branch.main.remote 2>/dev/null || echo "origin")

echo "fetching $PARENT_REMOTE in parent and submodules..."
git fetch "$PARENT_REMOTE" main --quiet
git submodule foreach --quiet '
  remote=$(git config --get branch.main.remote 2>/dev/null || echo "origin")
  git fetch "$remote" main --quiet || true
'

echo "resetting submodules to remote main..."
git submodule foreach --quiet '
  remote=$(git config --get branch.main.remote 2>/dev/null || echo "origin")
  git checkout -B main "$remote/main" >/dev/null 2>&1
  git reset --hard "$remote/main" --quiet
  git branch -D local-integration >/dev/null 2>&1 || true
'

echo "resetting parent to $PARENT_REMOTE/main..."
git checkout -B main "$PARENT_REMOTE/main" >/dev/null 2>&1
git reset --hard "$PARENT_REMOTE/main" --quiet
git branch -D local-integration >/dev/null 2>&1 || true

echo "syncing submodule working trees..."
git submodule update --recursive

echo ""
echo "done. parent and all submodules are at origin/main; local-integration deleted."
