            {
              "clientFileId": "patio",
              "filename": "patio.png",
              "contentType": "image/png",
              "sizeBytes": 4096
            }
          ]
        }
      },
      "finalize": {
        "files": [
          {
            "contentType": "image/jpeg",
            "sizeBytes": 2048,
            "widthPx": 1800,
            "heightPx": 1200
          },
          {
            "contentType": "image/png",
            "sizeBytes": 4096,
            "widthPx": 1600,
            "heightPx": 1000
          }
        ]
      },
      "expected": {
        "status": 201,
        "requestedVisibility": "public",
        "effectiveVisibility": "private",
        "finalizeStatus": 200,
        "mediaObjectCount": 2,
        "requiredVariants": ["original_safe", "large", "thumbnail", "blur_preview"],
        "sideEffects": ["variant_generation", "audit_event"]
      }
    },
    {
      "caseId": "property-gallery-deny-unresolved-property-target",
      "description": "Property media cannot claim an arbitrary catalog property ID from a booking hotel link.",
      "request": {
        "path": "/api/media/upload-sessions",
        "method": "POST",
        "body": {
          "purpose": "property.gallery_image",
          "visibility": "public",
          "resource": {
            "product": "booking",
            "resourceType": "booking_hotel",
            "resourceId": "booking_hotel_alpenrose",
            "propertyId": "property_elsewhere"
          },
          "files": [
            {
              "clientFileId": "hero",
              "filename": "alpine suite.jpg",
              "contentType": "image/jpeg",
              "sizeBytes": 2048
            }
          ]
        }
      },
      "expected": {
        "status": 403,
        "errorCode": "media_target_forbidden"
      }
    },
