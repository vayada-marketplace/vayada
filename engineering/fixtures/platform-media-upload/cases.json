{
  "contractVersion": "platform-media-upload.v1",
  "cases": [
    {
      "caseId": "property-gallery-upload-session",
      "description": "Hotel owner requests public property gallery media; upload stays private until domain approval.",
      "request": {
        "path": "/api/media/upload-sessions",
        "method": "POST",
        "body": {
          "purpose": "property.gallery_image",
          "visibility": "public",
          "resource": {
            "product": "booking",
            "resourceType": "booking_hotel",
            "resourceId": "booking_hotel_alpenrose",
            "propertyId": "property_alpenrose"
          },
          "files": [
            {
              "clientFileId": "hero",
              "filename": "alpine suite.jpg",
              "contentType": "image/jpeg",
              "sizeBytes": 2048
            }
          ]
        }
      },
      "finalize": {
        "files": [
          {
            "contentType": "image/jpeg",
            "sizeBytes": 2048,
            "checksumSha256": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
            "widthPx": 1800,
            "heightPx": 1200
          }
        ]
      },
      "expected": {
        "status": 201,
        "requestedVisibility": "public",
        "effectiveVisibility": "private",
        "finalizeStatus": 200,
        "mediaObjectCount": 1,
        "mediaObject": {
          "purpose": "property.gallery_image",
          "resourceProduct": "hotel_catalog",
          "resourceType": "property",
          "resourceId": "property_alpenrose",
          "approvalStatus": "pending_domain_approval",
          "lifecycleStatus": "staged"
        },
        "requiredVariants": ["original_safe", "large", "thumbnail", "blur_preview"],
        "sideEffects": ["variant_generation", "audit_event"]
      }
    },
    {
      "caseId": "property-gallery-batch-upload-session",
      "description": "Gallery upload sessions sign and finalize one media object per file.",
      "request": {
        "path": "/api/media/upload-sessions",
