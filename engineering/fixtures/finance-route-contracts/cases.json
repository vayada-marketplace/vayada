{
  "contractVersion": "finance-route-contracts.v1",
  "cases": [
    {
      "caseId": "payment-settings-read",
      "description": "Property finance settings expose payment capabilities and provider onboarding state without sensitive provider configuration.",
      "request": {
        "path": "/api/finance/properties/f3000000-0000-0000-0000-000000000686/payment-settings",
        "query": {}
      },
      "expected": {
        "status": 200,
        "mustInclude": [
          "contractVersion",
          "propertyId",
          "paymentSettings.paymentsEnabled",
          "paymentSettings.acceptedMethods",
          "paymentSettings.defaultCurrency",
          "paymentSettings.providerAccount.status",
          "paymentSettings.providerAccount.chargesEnabled",
          "paymentSettings.sourceFreshness"
        ],
        "mustExclude": [
          "stripeConnectAccountId",
          "xenditAccountNumber",
          "xenditAccountHolderName",
          "sensitiveConfigRef",
          "providerSecret",
          "legacyPmsTable"
        ],
        "enums": {
          "paymentSettings.acceptedMethods[]": [
            "card",
            "pay_at_property",
            "xendit",
            "cash",
            "bank_transfer",
            "manual_card",
            "wallet",
            "other"
          ]
        }
      }
    },
    {
      "caseId": "payment-settings-update-enqueues-redenomination",
      "description": "Payment settings writes are idempotent and queue audited side effects instead of inline cross-domain currency conversion.",
      "request": {
        "path": "/api/finance/properties/f3000000-0000-0000-0000-000000000686/payment-settings",
        "method": "PATCH",
        "body": {
          "commandId": "cmd-finance-payment-settings-001",
          "idempotencyKey": "finance-payment-settings-f300686-001",
          "defaultCurrency": "EUR",
          "acceptedMethods": ["card", "pay_at_property", "bank_transfer"],
          "paymentsEnabled": true
        }
      },
      "expected": {
        "status": 200,
        "commandMeta": {
          "contractVersion": "finance-route-contracts.v1",
          "idempotencyKey": "finance-payment-settings-f300686-001",
          "sideEffects": ["audit_event", "booking_projection_refresh"]
        },
        "mustNotCall": [
          "legacy BookingEngineDatabase",
          "legacy PMS hotel_payment_settings sync",
          "Stripe API",
          "Xendit API"
        ]
      }
    },
    {
      "caseId": "public-payment-capability-projection",
      "description": "Booking Web receives only public-safe payment capability fields derived from finance settings.",
      "request": {
        "path": "/api/booking-web/hotels/hotel-alpenrose/payment-settings",
        "query": {}
      },
      "expected": {
        "status": 200,
        "mustInclude": [
          "paymentMethods",
          "defaultCurrency",
          "depositPolicy",
          "cancellationPolicy.freeCancellationDays"
        ],
        "mustExclude": [
          "providerAccountId",
          "providerAccountRef",
          "payoutsEnabled",
          "xenditAccountNumber",
          "platformFeeValue",
          "financeVisibility"
        ]
      }
    },
    {
      "caseId": "cancellation-policy-update",
      "description": "Cancellation policy writes stay finance-owned and are exposed to checkout through a public-safe projection.",
      "request": {
        "path": "/api/finance/properties/f3000000-0000-0000-0000-000000000686/cancellation-policy",
        "method": "PATCH",
        "body": {
          "commandId": "cmd-cancellation-policy-001",
          "idempotencyKey": "finance-cancellation-policy-f300686-001",
          "freeCancellationDays": 7,
          "partialRefundPercent": 50,
          "refundMethod": "original_payment",
          "appliesTo": "direct_booking"
        }
      },
      "expected": {
        "status": 200,
        "mustInclude": [
          "policy.freeCancellationDays",
          "policy.partialRefundPercent",
          "commandMeta"
        ],
        "mustNotWrite": ["pms.cancellation_policy", "booking.guest_bookings.status"]
      }
    },
    {
      "caseId": "invoice-list-read",
      "description": "Invoice list is a finance read model over booking, PMS operation, and finance payment facts with stable pagination and counts.",
      "request": {
        "path": "/api/finance/properties/f3000000-0000-0000-0000-000000000686/invoices",
        "query": {
          "status": "partial",
          "limit": 50,
          "offset": 0,
          "sort": "issuedAt"
        }
      },
      "expected": {
        "status": 200,
        "itemCount": 2,
        "mustInclude": [
          "invoices[0].invoiceId",
          "invoices[0].invoiceNumber",
          "invoices[0].guestBookingId",
          "invoices[0].bookingReference",
          "invoices[0].guest.displayName",
          "invoices[0].totalAmount",
          "invoices[0].amountPaid",
          "invoices[0].balanceDue",
          "counts.partial",
          "sourceFreshness"
        ],
        "stableOrdering": "issuedAt DESC, invoiceNumber ASC",
        "mustExclude": ["guestBirthDate", "privatePmsNotes", "providerPaymentIntentId"]
      }
    },
    {
      "caseId": "invoice-detail-read",
      "description": "Invoice detail includes charge lines and settled payments while preserving Booking guest PII ownership.",
      "request": {
        "path": "/api/finance/properties/f3000000-0000-0000-0000-000000000686/invoices/inv_2026_abcd",
        "query": {}
      },
      "expected": {
        "status": 200,
        "mustInclude": [
          "invoice.invoiceId",
          "invoice.charges[0].description",
          "invoice.charges[0].amount",
          "invoice.payments[0].paymentId",
          "invoice.payments[0].method",
          "invoice.payments[0].status",
          "invoice.balanceDue"
        ],
        "mustExclude": [
          "payment.providerTransactionId",
          "payment.providerPaymentIntentId",
          "payment.processorFeeBreakdown",
          "booking_guests"
        ]
      }
    },
    {
      "caseId": "manual-payment-record-command",
      "description": "Manual payment records write finance payment facts idempotently and enqueue projection refresh jobs without provider calls.",
      "request": {
        "path": "/api/finance/properties/f3000000-0000-0000-0000-000000000686/invoices/inv_2026_abcd/payments",
        "method": "POST",
        "body": {
          "commandId": "cmd-manual-payment-001",
          "idempotencyKey": "finance-manual-payment-inv-2026-abcd-001",
          "amount": "250.00",
          "currency": "EUR",
          "paymentMethod": "cash",
          "reference": "front desk receipt 8812"
        }
      },
      "expected": {
        "status": 201,
        "mustInclude": [
          "invoice.payments[0].paymentId",
          "invoice.amountPaid",
          "invoice.balanceDue",
          "commandMeta.idempotencyKey"
        ],
        "commandMeta": {
          "sideEffects": ["audit_event", "booking_projection_refresh", "pms_projection_refresh"]
        },
        "mustNotCall": ["Stripe API", "Xendit API", "Channex API"]
      }
    },
    {
      "caseId": "manual-payment-record-command-idempotency-replay",
      "description": "Replaying the manual payment idempotency key returns the original payment and does not enqueue duplicate projection jobs.",
      "request": {
        "path": "/api/finance/properties/f3000000-0000-0000-0000-000000000686/invoices/inv_2026_abcd/payments",
        "method": "POST",
        "body": {
          "commandId": "cmd-manual-payment-001",
          "idempotencyKey": "finance-manual-payment-inv-2026-abcd-001",
          "amount": "250.00",
          "currency": "EUR",
          "paymentMethod": "cash",
          "reference": "front desk receipt 8812"
        }
      },
      "expected": {
        "status": 200,
        "mustInclude": [
          "invoice.payments[0].paymentId",
          "commandMeta.idempotencyKey",
          "commandMeta.jobs[0].status"
        ],
        "commandMeta": {
          "sideEffects": ["audit_event", "booking_projection_refresh", "pms_projection_refresh"]
        },
        "outboxEnqueueCount": 2
      }
    },
    {
      "caseId": "manual-payment-record-command-currency-mismatch",
      "description": "Manual payment commands reject payments whose currency does not match the invoice before writing payment facts.",
      "request": {
        "path": "/api/finance/properties/f3000000-0000-0000-0000-000000000686/invoices/inv_2026_abcd/payments",
        "method": "POST",
        "body": {
          "commandId": "cmd-manual-payment-currency-mismatch",
          "idempotencyKey": "finance-manual-payment-inv-2026-abcd-currency-mismatch",
          "amount": "250.00",
          "currency": "USD",
          "paymentMethod": "cash",
          "reference": "front desk receipt 8812"
        }
      },
      "expected": {
        "status": 400,
        "errorCode": "invalid_command"
      }
    },
    {
      "caseId": "manual-payment-record-command-overpayment",
