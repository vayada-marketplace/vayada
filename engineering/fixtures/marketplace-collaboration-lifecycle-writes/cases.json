      "caseId": "creator-create-collaboration-linked-resource",
      "request": {
        "method": "POST",
        "path": "/api/marketplace/collaborations",
        "action": "create",
        "side": "creator",
        "authRef": "creatorLinked",
        "idempotencyKey": "marketplace.collaboration.create:legacy_listing_688:nonce_creator:v1",
        "body": {
          "listingId": "legacy_listing_688",
          "creatorId": "legacy_creator_lina",
          "initiatorSide": "creator"
        }
      },
      "expected": {
        "status": 201,
        "authorizationMode": "creator_workspace_resource_link",
        "collaborationStatus": "pending",
        "mustInclude": ["collaboration.listingId", "collaboration.creatorId"],
        "mustNotWrite": ["pms.*", "finance.*", "affiliate.*"]
      }
    },
    {
