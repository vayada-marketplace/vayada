{
  "contractVersion": "jobs-events.v1",
  "cases": [
    {
      "caseId": "booking-confirmed-enqueues-side-effects",
      "description": "A committed booking status change records an event and enqueues durable side-effect jobs.",
      "input": {
        "eventType": "booking.status_changed",
        "aggregate": {
          "type": "booking",
          "id": "book_123"
        },
        "organizationId": "org_hotel_alpenrose",
        "requestId": "req_001",
        "correlationId": "corr_booking_001",
        "payload": {
          "fromStatus": "pending",
          "toStatus": "confirmed",
          "roomTypeId": "rt_deluxe",
          "checkIn": "2026-09-12",
          "checkOut": "2026-09-15"
        }
      },
      "expected": {
        "domainEventStatus": "recorded",
        "jobs": [
          {
            "jobType": "email.booking-status-changed",
            "idempotencyKey": "email.booking-status-changed:booking:book_123:guest-confirmed:v1"
          },
          {
            "jobType": "channex.push-availability",
            "idempotencyKey": "channex.push-availability:room_type:rt_deluxe:2026-09-12_2026-09-15:v1"
          }
        ],
        "auditCorrelation": {
          "requestId": "req_001",
          "correlationId": "corr_booking_001",
          "causationId": "booking.status_changed:book_123",
          "organizationId": "org_hotel_alpenrose",
          "actor": {
            "type": "internal_user",
            "id": "user_hotel_admin_001"
          },
          "resourceIds": ["booking:book_123", "room_type:rt_deluxe"],
          "source": "apps/api.booking-status"
        }
      }
    },
    {
      "caseId": "duplicate-enqueue-reuses-idempotency",
      "description": "A repeated enqueue with the same semantic key does not create duplicate customer-facing work.",
      "existingJob": {
        "jobType": "email.booking-status-changed",
        "idempotencyKey": "email.booking-status-changed:booking:book_123:guest-confirmed:v1",
        "status": "succeeded"
      },
      "enqueue": {
        "jobType": "email.booking-status-changed",
        "idempotencyKey": "email.booking-status-changed:booking:book_123:guest-confirmed:v1"
      },
      "expected": {
        "createdNewJob": false,
        "returnedStatus": "succeeded",
        "attemptsAdded": 0
      }
    },
    {
      "caseId": "retry-exhaustion-dead-letters",
      "description": "A retryable provider failure records attempts and becomes visible after max attempts.",
      "job": {
        "jobType": "channex.push-availability",
        "idempotencyKey": "channex.push-availability:room_type:rt_deluxe:2026-09-12_2026-09-15:v1",
        "maxAttempts": 5,
        "failureCategory": "provider_5xx"
      },
      "expected": {
        "finalStatus": "dead_lettered",
        "attemptCount": 5,
        "deadLetter": {
          "jobId": "job_channex_push_availability_001",
          "idempotencyKey": "channex.push-availability:room_type:rt_deluxe:2026-09-12_2026-09-15:v1",
          "errorCategory": "provider_5xx",
          "affectedOrganizationId": "org_hotel_alpenrose",
          "affectedResource": {
            "type": "room_type",
            "id": "rt_deluxe"
          },
          "lastAttemptAt": "2026-06-04T09:45:00Z",
          "replayEligible": true,
          "ownerPackage": "backend-events",
          "auditEventType": "job.dead_lettered"
        }
      }
    },
    {
      "caseId": "pms-incremental-ari-push-reuses-idempotency-window",
      "description": "A pms.inventory.ari_changed outbox event enqueues one Channex ARI push for the room/date/inventory-version window; duplicate scheduler claims reuse the same job.",
      "input": {
        "eventType": "pms.inventory.ari_changed",
        "propertyId": "prop_alpenrose",
        "roomTypeId": "rt_deluxe",
        "dateRange": {
          "from": "2026-09-12",
          "to": "2026-09-15"
        },
        "inventoryVersion": "outbox-ari-001",
        "outboxKey": "pms.inventory.ari_changed:prop_alpenrose:rt_deluxe:2026-09-12_2026-09-15"
      },
      "expected": {
        "domainEventKey": "channex.push-ari:prop_alpenrose:rt_deluxe:2026-09-12_2026-09-15:outbox-ari-001:v1",
        "job": {
          "jobType": "channex.push-ari",
          "queueName": "pms.channex.scheduler",
          "idempotencyKey": "channex.push-ari:room_type:rt_deluxe:2026-09-12_2026-09-15:outbox-ari-001:v1"
        },
        "duplicateClaim": {
          "createdNewJob": false,
          "providerAttemptsAdded": 0
        }
      }
    },
    {
      "caseId": "pms-full-ari-push-persists-provider-attempt",
      "description": "The full ARI scheduler writes Channex provider attempt evidence with the provider request id for rehearsal audit.",
      "job": {
        "jobType": "channex.push-ari",
        "idempotencyKey": "channex.push-ari:room_type:rt_suite:2026-09-01_2027-03-01:full-2026-09-01:v1",
        "propertyId": "prop_alpenrose",
        "roomTypeId": "rt_suite",
        "maxAttempts": 5
      },
      "providerAttempt": {
        "provider": "channex",
        "providerRequestId": "chx_req_full_1",
        "attemptNumber": 1,
        "status": "succeeded",
        "statusCode": 200,
        "requestPayloadHash": "sha256:<stable-ari-payload>"
      },
      "expected": {
        "jobStatus": "succeeded",
        "attemptRecordPersisted": true,
        "auditEvidenceFields": [
          "providerRequestId",
          "jobKey",
          "attemptNumber",
          "requestPayloadHash"
        ]
      }
    },
    {
      "caseId": "pms-ari-provider-retry-dead-letters",
      "description": "Retryable Channex failures append provider attempts and create a dead-letter record after max attempts.",
      "job": {
        "jobType": "channex.push-ari",
        "idempotencyKey": "channex.push-ari:room_type:rt_deluxe:2026-09-12_2026-09-15:outbox-ari-retry-001:v1",
        "maxAttempts": 5,
        "failureCategory": "provider_5xx"
      },
      "expected": {
        "attemptCount": 5,
        "providerAttemptRecords": 5,
        "finalStatus": "dead_lettered",
        "deadLetter": {
          "reasonCode": "max_attempts_exhausted",
          "replayEligible": true,
          "ownerPackage": "backend-events"
        }
      }
    },
    {
      "caseId": "pms-rolling-calendar-auto-open-window-idempotency",
      "description": "The rolling calendar auto-open scheduler opens inventory through one semantic open-through date per property and reuses that key on duplicate runs.",
      "input": {
        "propertyId": "prop_alpenrose",
        "openFrom": "2027-09-01",
        "openThrough": "2028-03-02",
        "roomTypeIds": ["rt_deluxe", "rt_suite"]
      },
      "expected": {
        "domainEventKey": "pms.calendar-auto-open:prop_alpenrose:2028-03-02:v1",
        "job": {
          "jobType": "pms.calendar-auto-open",
          "queueName": "pms.channex.scheduler",
          "idempotencyKey": "pms.calendar-auto-open:property:prop_alpenrose:open-through-2028-03-02:v1"
        },
        "duplicateRun": {
          "createdNewJob": false,
          "openedInventoryDays": 0
        }
      }
    }
  ]
}
