{
  "contractVersion": "marketplace-hotel-self-service.v1",
  "cases": [
    {
      "caseId": "profile-status-linked-complete",
      "description": "A hotel-group organization with an owner resource link can read complete marketplace profile status.",
      "request": {
        "method": "GET",
        "path": "/api/marketplace/hotels/me/profile-status",
        "auth": {
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": [
            {
              "product": "marketplace",
              "resourceType": "hotel_profile",
              "resourceId": "property_alpenrose",
              "relationship": "owner"
            }
          ]
        }
      },
      "fixtureNotes": "Seed hotel_catalog property facts, one marketplace_hotel_profiles row with profile_complete=true, and one non-archived listing.",
      "expected": {
        "status": 200,
        "authorizationMode": "organization_resource_link",
        "propertyId": "property_alpenrose",
        "profileComplete": true,
        "missingFields": [],
        "missingListings": false,
        "hasDefaults": { "location": false },
        "mustExclude": [
          "user_id",
          "userId",
          "owner_email",
          "ownerEmail",
          "hotel_profile_id",
          "hotelProfileId"
        ]
      }
    },
    {
      "caseId": "profile-read-linked-with-listings",
      "description": "Profile read returns canonical property facts from hotel catalog plus marketplace-owned profile/listing state.",
      "request": {
        "method": "GET",
        "path": "/api/marketplace/hotels/me",
        "auth": {
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": [
            {
              "product": "marketplace",
              "resourceType": "hotel_profile",
              "resourceId": "property_alpenrose",
              "relationship": "owner"
            }
          ]
        }
      },
      "expected": {
        "status": 200,
        "authorizationMode": "organization_resource_link",
        "mustInclude": [
          "property.propertyId",
          "property.publicId",
          "property.displayName",
          "property.canonicalSlug",
          "property.location.displayText",
          "property.coverImageUrl",
          "marketplaceProfile.propertyId",
          "marketplaceProfile.organizationId",
          "marketplaceProfile.marketplaceProfileStatus",
          "marketplaceProfile.hostSummary",
          "listings[0].listingId",
          "listings[0].title",
          "listings[0].collaborationOfferings[0].collaborationType",
          "listings[0].creatorRequirements.platforms"
        ],
        "mustExclude": [
          "user_id",
          "userId",
          "owner_email",
          "ownerEmail",
          "hotel_profile_id",
          "hotelProfileId"
        ],
        "ownership": {
          "property.displayName": "hotel_catalog.property_public_profile_read_model.display_name",
          "property.location": "hotel_catalog.property_public_profile_read_model.location",
          "marketplaceProfile.hostSummary": "marketplace.marketplace_hotel_profiles.host_summary",
          "listings[].title": "marketplace.marketplace_hotel_listings.title"
        },
        "idContinuity": "listings[].listingId equals marketplace_hotel_listings.source_listing_id and the V1 discovery listingId for the same row"
      }
    },
    {
      "caseId": "profile-read-legacy-user-id-fallback",
      "description": "A migrated hotel user without an organization resource link can be resolved through the documented temporary user_id fallback.",
      "request": {
        "method": "GET",
        "path": "/api/marketplace/hotels/me",
        "auth": {
          "internalUserId": "legacy_user_alpenrose",
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": []
        }
      },
      "fixtureNotes": "Seed one legacy hotel_profiles row for legacy_user_alpenrose and one marketplace_hotel_profiles row with source_system='migration' and matching source_hotel_profile_id.",
      "expected": {
        "status": 200,
        "authorizationMode": "legacy_user_id_fallback",
        "propertyId": "property_alpenrose",
        "audit": { "fallbackUsed": true },
        "mustExclude": [
          "user_id",
          "userId",
          "owner_email",
          "ownerEmail",
          "legacyJwtClaims",
          "users.type"
        ]
      }
    },
    {
      "caseId": "profile-read-denies-missing-resource-link",
      "description": "A user with marketplace.profile.manage but no linked marketplace hotel profile and no fallback match is denied.",
      "request": {
        "method": "GET",
        "path": "/api/marketplace/hotels/me",
        "auth": {
          "internalUserId": "user_unlinked",
          "organizationId": "org_hotel_group_unlinked",
          "permission": "marketplace.profile.manage",
          "linkedResources": []
        }
      },
      "expected": {
        "status": 403,
        "errorCode": "missing_resource_link"
      }
    },
    {
      "caseId": "profile-update-marketplace-fields-only",
      "description": "Profile PUT updates marketplace_hotel_profiles fields while canonical hotel catalog facts remain unchanged.",
      "request": {
        "method": "PUT",
        "path": "/api/marketplace/hotels/me",
        "auth": {
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": [
            {
              "product": "marketplace",
              "resourceType": "hotel_profile",
              "resourceId": "property_alpenrose",
              "relationship": "operator"
            }
          ]
        },
        "body": {
          "hostSummary": "We host creator stays focused on alpine wellness and slow travel.",
          "collaborationGuidelines": "Send preferred months, platform plan, and examples of prior hotel work."
        }
      },
      "expected": {
        "status": 200,
        "updatedColumns": [
          "marketplace.marketplace_hotel_profiles.host_summary",
          "marketplace.marketplace_hotel_profiles.collaboration_guidelines",
          "marketplace.marketplace_hotel_profiles.updated_at"
        ],
        "unchangedColumns": [
          "hotel_catalog.properties.display_name",
          "hotel_catalog.property_public_profile_read_model.location",
          "hotel_catalog.property_contact_channels",
          "hotel_catalog.property_media"
        ],
        "response": {
          "marketplaceProfile.hostSummary": "We host creator stays focused on alpine wellness and slow travel.",
          "marketplaceProfile.collaborationGuidelines": "Send preferred months, platform plan, and examples of prior hotel work."
        }
      }
    },
    {
      "caseId": "profile-update-rejects-canonical-property-fields",
      "description": "Legacy profile fields owned by hotel catalog are rejected by the marketplace V2 profile route.",
      "request": {
        "method": "PUT",
        "path": "/api/marketplace/hotels/me",
        "auth": {
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": [
            {
              "product": "marketplace",
              "resourceType": "hotel_profile",
              "resourceId": "property_alpenrose",
              "relationship": "owner"
            }
          ]
        },
        "body": {
          "name": "Renamed Hotel",
          "location": "Zurich, Switzerland",
          "email": "owner@example.com",
          "website": "https://example.com",
          "phone": "+41 44 000 0000",
          "picture": "https://cdn.example.com/hotel.jpg"
        }
      },
      "expected": {
        "status": 400,
        "errorCode": "canonical_property_read_only",
        "messageIncludes": "hotel catalog"
      }
    },
    {
      "caseId": "listing-create-preserves-discovery-id",
      "description": "Creating a listing assigns source_listing_id before response/projection so self-service and discovery expose the same listingId.",
      "request": {
        "method": "POST",
        "path": "/api/marketplace/hotels/me/listings",
        "auth": {
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": [
            {
              "product": "marketplace",
              "resourceType": "hotel_profile",
              "resourceId": "property_alpenrose",
              "relationship": "owner"
            }
          ]
        },
        "body": {
          "title": "Alpine spa creator stay",
          "listingSummary": "Two-night hosted stay for wellness creators.",
          "accommodationType": "boutique_hotel",
          "rawLocationText": "Zermatt, Switzerland",
          "imageUrls": ["https://cdn.example.com/listing/spa.jpg"],
          "collaborationOfferings": [
            {
              "collaborationType": "free_stay",
              "availabilityMonths": ["2026-09", "2026-10"],
              "platforms": ["instagram", "tiktok"],
              "freeStayMinNights": 2,
              "freeStayMaxNights": 3,
              "paidMaxAmount": null,
              "discountPercentage": null,
              "commissionPercentage": null,
              "minFollowers": 10000,
              "currency": "EUR",
              "termsSummary": "Breakfast included."
            }
          ],
          "creatorRequirements": {
            "platforms": ["instagram", "tiktok"],
            "targetCountries": ["CH", "DE", "AT"],
            "targetAgeMin": 25,
            "targetAgeMax": 44,
            "targetAgeGroups": ["25-34", "35-44"],
            "creatorTypes": ["travel", "lifestyle"]
          }
        }
      },
      "expected": {
        "status": 201,
        "mustInclude": ["listingId", "listingStatus", "createdAt", "updatedAt"],
        "listingIdSource": "marketplace.marketplace_hotel_listings.source_listing_id",
        "listingIdNotNull": true,
        "createdResourceLink": {
          "product": "marketplace",
          "resourceType": "hotel_listing",
          "resourceIdSource": "marketplace.marketplace_hotel_listings.id",
          "relationship": "owner",
          "organizationId": "org_hotel_group_alpenrose"
        },
        "discoveryReadModel": {
          "sameListingId": true,
          "refreshedFields": [
            "listing_title",
            "listing_summary",
            "accommodation_type",
            "location",
            "image_urls",
            "public_offering_summary",
            "public_creator_requirements",
            "projected_at"
          ]
        },
        "enums": {
          "collaborationOfferings[].collaborationType": [
            "free_stay",
            "paid",
            "discount",
            "affiliate"
          ],
          "collaborationOfferings[].platforms[]": [
            "instagram",
            "tiktok",
            "youtube",
            "facebook",
            "blog",
            "x",
            "other"
          ]
        }
      }
    },
    {
      "caseId": "listing-update-preserves-id-continuity",
      "description": "Updating a migrated listing keeps listingId stable and refreshes the public discovery projection.",
      "request": {
        "method": "PUT",
        "path": "/api/marketplace/hotels/me/listings/legacy_listing_alpenrose",
        "auth": {
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": [
            {
              "product": "marketplace",
              "resourceType": "hotel_profile",
              "resourceId": "property_alpenrose",
              "relationship": "operator"
            },
            {
              "product": "marketplace",
              "resourceType": "hotel_listing",
              "resourceId": "f7969000-0000-0000-0000-000000000111",
              "relationship": "operator"
            }
          ]
        },
        "body": {
          "title": "Updated alpine spa creator stay",
          "listingSummary": "Updated summary for autumn creators.",
          "imageUrls": ["https://cdn.example.com/listing/spa-updated.jpg"]
        }
      },
      "expected": {
        "status": 200,
        "listingId": "legacy_listing_alpenrose",
        "authorization": {
          "publicListingId": "legacy_listing_alpenrose",
          "resourceType": "hotel_listing",
          "resourceId": "f7969000-0000-0000-0000-000000000111",
          "resourceIdSource": "marketplace.marketplace_hotel_listings.id"
        },
        "unchangedColumns": ["marketplace.marketplace_hotel_listings.source_listing_id"],
        "discoveryReadModel": {
          "sameListingId": true,
          "projectedAtAdvanced": true
        }
      }
    },
    {
      "caseId": "listing-delete-archives-and-removes-discovery",
      "description": "Deleting a listing archives the marketplace row and removes or privatizes its discovery read model row.",
      "request": {
        "method": "DELETE",
        "path": "/api/marketplace/hotels/me/listings/legacy_listing_alpenrose",
        "auth": {
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": [
            {
              "product": "marketplace",
              "resourceType": "hotel_profile",
              "resourceId": "property_alpenrose",
              "relationship": "owner"
            },
            {
              "product": "marketplace",
              "resourceType": "hotel_listing",
              "resourceId": "f7969000-0000-0000-0000-000000000111",
              "relationship": "owner"
            }
          ]
        }
      },
      "expected": {
        "status": 204,
        "authorization": {
          "publicListingId": "legacy_listing_alpenrose",
          "resourceType": "hotel_listing",
          "resourceId": "f7969000-0000-0000-0000-000000000111",
          "resourceIdSource": "marketplace.marketplace_hotel_listings.id"
        },
        "listingStatus": "archived",
        "discoveryReadModel": {
          "publicListingAbsent": true,
          "allowedOutcomes": ["read_model_row_deleted", "visibility_status_not_public"]
        },
        "idNotReused": "legacy_listing_alpenrose"
      }
    },
    {
      "caseId": "listing-write-validates-type-specific-fields",
      "description": "Offering and creator requirement validation failures return the contract error envelope.",
      "request": {
        "method": "POST",
        "path": "/api/marketplace/hotels/me/listings",
        "auth": {
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": [
            {
              "product": "marketplace",
              "resourceType": "hotel_profile",
              "resourceId": "property_alpenrose",
              "relationship": "owner"
            }
          ]
        },
        "body": {
          "title": "Invalid paid stay",
          "collaborationOfferings": [
            {
              "collaborationType": "paid",
              "availabilityMonths": ["2026-09"],
              "platforms": ["instagram"],
              "paidMaxAmount": null
            }
          ],
          "creatorRequirements": {
            "platforms": ["instagram"],
            "targetAgeMin": 45,
            "targetAgeMax": 24
          }
        }
      },
      "alsoRejects": [
        "free_stay without min/max nights",
        "discount without discountPercentage",
        "affiliate without commissionPercentage",
        "empty collaborationOfferings",
        "creatorRequirements.targetAgeMax less than targetAgeMin"
      ],
      "expected": {
        "status": 422,
        "errorCode": "validation_failed"
      }
    },
    {
      "caseId": "listing-update-denies-unlinked-listing",
      "description": "A hotel profile owner cannot update a listing that is not linked to the selected organization.",
      "request": {
        "method": "PUT",
        "path": "/api/marketplace/hotels/me/listings/other_org_listing",
        "auth": {
          "organizationId": "org_hotel_group_alpenrose",
          "permission": "marketplace.profile.manage",
          "linkedResources": [
            {
              "product": "marketplace",
              "resourceType": "hotel_profile",
              "resourceId": "property_alpenrose",
              "relationship": "owner"
            },
            {
              "product": "marketplace",
              "resourceType": "hotel_listing",
              "resourceId": "f7969000-0000-0000-0000-000000000999",
              "relationship": "owner"
            }
          ]
        },
        "body": {
          "title": "Unauthorized edit"
        }
      },
      "expected": {
        "status": 403,
        "errorCode": "missing_resource_link",
        "resolvedListingResourceId": "f7969000-0000-0000-0000-000000000222",
        "linkedListingResourceId": "f7969000-0000-0000-0000-000000000999"
      }
    }
  ]
}
