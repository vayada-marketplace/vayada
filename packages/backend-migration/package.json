{
  "name": "@vayada/backend-migration",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Target schema SQL migration runner and local parity harness for the TypeScript backend.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "target:migrate": "tsx src/cli/migrate.ts",
    "target:rebuild": "tsx src/cli/rebuild.ts",
    "target:parity": "tsx src/cli/parity.ts",
    "target:c1-rehearsal:checks": "tsx src/cli/c1RehearsalChecks.ts",
    "target:platform-identity:bootstrap": "tsx src/cli/platformIdentityBootstrap.ts",
    "target:workos:backfill": "tsx src/cli/workosBackfill.ts",
    "target:workos:audit": "tsx src/cli/workosLinkAudit.ts",
    "target:fixtures:smoke": "tsx src/cli/smoke.ts",
    "target:migrate:dist": "node dist/cli/migrate.js",
    "target:platform-identity:bootstrap:dist": "node dist/cli/platformIdentityBootstrap.js",
    "target:workos:backfill:dist": "node dist/cli/workosBackfill.js",
    "target:workos:audit:dist": "node dist/cli/workosLinkAudit.js"
  },
  "dependencies": {
    "@workos-inc/node": "^10.2.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
