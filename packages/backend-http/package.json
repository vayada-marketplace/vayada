{
  "name": "@vayada/backend-http",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared HTTP helpers for the TypeScript backend scaffold.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "pretest": "npm --workspace @vayada/backend-test run build",
    "pretypecheck": "npm --workspace @vayada/backend-test run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@vayada/backend-test": "0.0.0",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
