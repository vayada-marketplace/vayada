# marketplace-api
# Code defaults to portless URL; set only to override.
#   portless default:  https://api.marketplace.localhost
#   plain-port dev:    http://localhost:8000
#   production:        https://api.vayada.com
# NEXT_PUBLIC_API_URL=

# PMS frontend (deep-link target for the product chooser → PMS login)
# Default in code: https://pms.vayada.com (prod).
#   portless dev:      https://pms.localhost
#   plain-port dev:    http://localhost:3004
NEXT_PUBLIC_PMS_URL=https://pms.vayada.com

# Authenticated app (creator marketplace) — auth/app CTAs from this site
# Default in code: https://app.vayada.com (prod).
#   portless dev:      https://marketplace.localhost
#   plain-port dev:    http://localhost:3000
NEXT_PUBLIC_APP_URL=https://app.vayada.com

# Node Environment
# Set to 'development' for local development, 'production' for production builds
NODE_ENV=development
