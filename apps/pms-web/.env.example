# Code defaults to portless URLs. Set these only to override.

# booking-api (auth)
#   portless default:  https://api.booking.localhost
#   plain-port dev:    http://localhost:8001
# NEXT_PUBLIC_AUTH_API_URL=

# pms-api
#   portless default:  https://api.pms.localhost
#   plain-port dev:    http://localhost:8002
# NEXT_PUBLIC_PMS_API_URL=

# TypeScript backend PMS operations routes.
#   portless default:  https://api.localhost
#   plain-port dev:    http://localhost:8003
# NEXT_PUBLIC_PMS_OPERATIONS_API_URL=

# apps/api platform media upload-session and import-job API
#   portless default:  https://api.localhost
#   plain-port dev:    http://localhost:8003
# NEXT_PUBLIC_PLATFORM_MEDIA_API_URL=

# Marketplace frontend app-switcher target.
#   local portless:    https://marketplace.localhost
#   next env:          https://next-marketplace.vayada.com
#   production:        https://app.vayada.com
# NEXT_PUBLIC_MARKETPLACE_URL=
# Set false only for an intentional rollback to the legacy PMS helpers.
# NEXT_PUBLIC_PMS_OPERATIONS_READS_ENABLED=true

# Rollback switch for VAY-802. Set to "false" to return /login to legacy password auth.
# NEXT_PUBLIC_AUTHKIT_LOGIN_ENABLED=true

# Temporary fallback for unlinked users during the rollout window. Omitted/false
# keeps legacy password auth hidden; set true only for an intentional rollback.
# NEXT_PUBLIC_AUTHKIT_LEGACY_FALLBACK_ENABLED=true

# Temporary compatibility JWT bridge for browser calls to unmigrated legacy APIs.
# Omitted/false keeps the bridge disabled; set true only for an intentional
# legacy compatibility rollout.
# NEXT_PUBLIC_AUTHKIT_COMPATIBILITY_TOKEN_ENABLED=true
