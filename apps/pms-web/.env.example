# Code defaults to portless URLs. Set these only to override.

# booking-api (auth)
#   portless default:  https://api.booking.localhost
#   plain-port dev:    http://localhost:8001
# NEXT_PUBLIC_AUTH_API_URL=

# pms-api
#   portless default:  https://api.pms.localhost
#   plain-port dev:    http://localhost:8002
# NEXT_PUBLIC_PMS_API_URL=
