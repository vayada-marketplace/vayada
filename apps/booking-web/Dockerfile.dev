FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install

# The package-lock.json is usually generated on macOS, so the platform-
# specific @next/swc-* binary for linux/arm64-musl (Alpine on Apple
# Silicon) is not resolved during `npm install`. Explicitly install it
# so `next dev` doesn't crash at boot with "Failed to load SWC binary".
RUN NEXT_VERSION=$(node -p "require('./package.json').dependencies.next || require('./package.json').devDependencies.next" | sed 's/[^0-9.]//g') && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then \
      npm install --no-save "@next/swc-linux-arm64-musl@${NEXT_VERSION}" ; \
    elif [ "$ARCH" = "x86_64" ]; then \
      npm install --no-save "@next/swc-linux-x64-musl@${NEXT_VERSION}" ; \
    fi

COPY . .

EXPOSE 3002

CMD ["npm", "run", "dev"]
