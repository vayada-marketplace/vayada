# Code defaults to portless URLs (https://api.*.localhost). Set these
# only to override (e.g. plain-port dev without portless).

# booking-api
#   portless default:  https://api.booking.localhost
#   plain-port dev:    http://localhost:8001
# NEXT_PUBLIC_API_URL=

# pms-api
#   portless default:  https://api.pms.localhost
#   plain-port dev:    http://localhost:8002
# NEXT_PUBLIC_PMS_URL=

# Reservations contract screen (build-time flag; NEXT_PUBLIC_* is inlined at build).
# Enable only when NEXT_PUBLIC_API_URL routes
# /api/booking/hotels/:hotelId/reservations to the TypeScript backend (apps/api)
# AND apps/api has BOOKING_RESERVATIONS_READ_DATABASE_URL configured.
# Cutover/rollback runbook: ../../engineering/booking-reservations-cutover-runbook.md
# Rollback: set to false (or unset) and rebuild booking-admin to hide the surface.
# NEXT_PUBLIC_BOOKING_RESERVATIONS_ENABLED=false
