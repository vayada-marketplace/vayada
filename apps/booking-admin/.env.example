# Code defaults to portless URLs (https://api.*.localhost). Set these
# only to override (e.g. plain-port dev without portless).

# booking-api
#   portless default:  https://api.booking.localhost
#   plain-port dev:    http://localhost:8001
# NEXT_PUBLIC_API_URL=

# apps/api — AuthKit session/callback/logout API used by the WorkOS cutover.
#   portless default:  https://api.localhost
#   plain-port dev:    http://localhost:8003
# NEXT_PUBLIC_AUTH_API_URL=

# apps/api platform media upload-session API
#   portless default:  https://api.localhost
#   plain-port dev:    http://localhost:8003
# NEXT_PUBLIC_PLATFORM_MEDIA_API_URL=

# Rollback switch for VAY-802. Set to "false" to return /login to legacy password auth.
# NEXT_PUBLIC_AUTHKIT_LOGIN_ENABLED=true

# Temporary fallback for unlinked users during the rollout window. Omitted/false
# keeps legacy password auth hidden; set true only for an intentional rollback.
# NEXT_PUBLIC_AUTHKIT_LEGACY_FALLBACK_ENABLED=true

# Temporary compatibility JWT bridge for browser calls to unmigrated legacy APIs.
# Omitted keeps the bridge enabled for rollout compatibility; next-api target-only
# deployments set this to false so AuthKit access tokens remain the default bearer.
# NEXT_PUBLIC_AUTHKIT_COMPATIBILITY_TOKEN_ENABLED=false

# pms-api
#   portless default:  https://api.pms.localhost
#   plain-port dev:    http://localhost:8002
# NEXT_PUBLIC_PMS_URL=

# Reservations contract screen (build-time flag; NEXT_PUBLIC_* is inlined at build).
# Enable only when NEXT_PUBLIC_API_URL routes
# /api/booking/hotels/:hotelId/reservations to the TypeScript backend (apps/api)
# AND apps/api has BOOKING_RESERVATIONS_READ_DATABASE_URL configured.
# Cutover/rollback runbook: ../../engineering/booking-reservations-cutover-runbook.md
# Rollback: set to false (or unset) and rebuild booking-admin to hide the surface.
# NEXT_PUBLIC_BOOKING_RESERVATIONS_ENABLED=false
