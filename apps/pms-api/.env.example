DATABASE_URL=postgresql://vayada_pms_user:vayada_pms_password@localhost:5436/vayada_pms_db
AUTH_DATABASE_URL=postgresql://vayada_auth_user:vayada_auth_password@localhost:5435/vayada_auth_db
BOOKING_ENGINE_DATABASE_URL=postgresql://vayada_booking_user:vayada_booking_password@localhost:5434/vayada_booking_db

JWT_SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3007

API_HOST=0.0.0.0
API_PORT=8002

# SMTP (optional — emails silently skipped when SMTP_HOST is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@vayada.com
SMTP_USE_TLS=true

# S3 / MinIO (local dev — same MinIO instance as marketplace)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=vayada-uploads
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_USE_PUBLIC_URLS=true

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_ACCOUNT_ID=

# Xendit (for Indonesian payouts)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_SECRET=

# Channex channel manager
CHANNEX_API_BASE_URL=https://staging.channex.io
CHANNEX_API_KEY=
CHANNEX_POLL_INTERVAL_MINUTES=5
CHANNEX_FULL_SYNC_HOUR=4
CHANNEX_API_DELAY_SECONDS=0.5

# Legacy scheduler cutover controls
# Set PMS_SCHEDULER_ENABLED=false to freeze all legacy PMS scheduler jobs.
# Otherwise use comma-separated job ids to allow or block individual jobs.
# Job ids:
# expire_pending_bookings,cancel_stale_unpaid_bookings,cleanup_expired_drafts,
# process_property_payouts,process_affiliate_payouts,poll_xendit_processing_payouts,
# poll_channex_bookings,full_channex_ari_sync,advance_calendar_auto_open_windows
PMS_SCHEDULER_ENABLED=true
PMS_SCHEDULER_JOB_ALLOWLIST=
PMS_SCHEDULER_JOB_BLOCKLIST=

ENVIRONMENT=development
DEBUG=true
