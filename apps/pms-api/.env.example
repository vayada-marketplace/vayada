DATABASE_URL=postgresql://vayada_pms_user:vayada_pms_password@localhost:5436/vayada_pms_db
AUTH_DATABASE_URL=postgresql://vayada_auth_user:vayada_auth_password@localhost:5435/vayada_auth_db

JWT_SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3002,http://localhost:3003,http://localhost:3004

API_HOST=0.0.0.0
API_PORT=8002

# SMTP (optional — emails silently skipped when SMTP_HOST is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@vayada.com
SMTP_USE_TLS=true

# S3 / MinIO (local dev — same MinIO instance as marketplace)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=vayada-uploads
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_USE_PUBLIC_URLS=true

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_ACCOUNT_ID=

# Xendit (for Indonesian payouts)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_SECRET=

ENVIRONMENT=development
DEBUG=true
