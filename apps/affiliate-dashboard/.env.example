# All variables are optional in dev. Code defaults to portless URLs
# (https://api.*.localhost). Set these only if you want to override
# (e.g. plain-port dev without portless, or staging endpoints).

# Auth API (apps/api) — AuthKit login/session/logout.
#   portless default:  https://api.localhost
#   plain-port dev:    http://localhost:8003
# NEXT_PUBLIC_AUTH_API_URL=

# Temporary compatibility JWT bridge for browser calls to unmigrated legacy APIs.
# Omitted keeps the bridge enabled for rollout compatibility; next-api target-only
# deployments set this to false so AuthKit access tokens remain the default bearer.
# NEXT_PUBLIC_AUTHKIT_COMPATIBILITY_TOKEN_ENABLED=false

# PMS API — temporary legacy affiliate dashboard data.
#   portless default:  https://api.pms.localhost
#   plain-port dev:    http://localhost:8002
# NEXT_PUBLIC_API_URL=

# Public-facing host for affiliate referral links
# (e.g. {hotelSlug}.{SITE_HOST}?ref={code}). Override per environment —
# in staging this should point at the staging marketplace host.
NEXT_PUBLIC_SITE_HOST=vayada.com
