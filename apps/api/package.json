{
  "name": "vayada-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "portless": {
    "name": "api"
  },
  "scripts": {
    "build:backend-packages": "npm --workspace @vayada/backend-config run build && npm --workspace @vayada/backend-http run build && npm --workspace @vayada/backend-db run build && npm --workspace @vayada/backend-auth run build && npm --workspace @vayada/backend-authorization run build && npm --workspace @vayada/backend-test run build && npm --workspace @vayada/domain-distribution run build && npm --workspace @vayada/domain-intelligence run build",
    "prebuild": "npm run build:backend-packages",
    "predev": "npm run build:backend-packages",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "pretest": "npm run build:backend-packages",
    "start": "node dist/server.js",
    "test": "vitest run",
    "pretypecheck": "npm run build:backend-packages",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vayada/backend-auth": "0.0.0",
    "@vayada/backend-authorization": "0.0.0",
    "@vayada/backend-config": "0.0.0",
    "@vayada/backend-db": "0.0.0",
    "@vayada/backend-http": "0.0.0",
    "@vayada/domain-distribution": "0.0.0",
    "@vayada/domain-intelligence": "0.0.0",
    "@workos-inc/node": "^10.2.0",
    "fastify": "^5.7.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@vayada/backend-test": "0.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
