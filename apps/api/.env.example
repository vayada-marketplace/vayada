# apps/api local environment contract
#
# Values are optional unless the related source/cutover flag is enabled.

HOST=0.0.0.0
PORT=8003

# Runtime guard
#
# Local development keeps the legacy-compatible defaults unless a source flag is
# set explicitly. The next-stack production image bakes API_RUNTIME=next at
# build time, so it fails boot if any legacy product runtime URL/DB env is
# present:
# BOOKING_DATABASE_URL, BOOKING_RESERVATIONS_READ_DATABASE_URL,
# BOOKING_PUBLIC_API_URL, PMS_API_URL, or PMS_PUBLIC_API_URL.
# API_RUNTIME=next
# TARGET_DATABASE_URL=postgresql://...
# PUBLIC_HOTEL_PROFILE_SOURCE=target
# BOOKING_DOMAIN_RESOLUTION_SOURCE=target
# PUBLIC_BOOKABILITY_SOURCE=target
# BOOKING_SETTINGS_SOURCE=target
# BOOKING_RESERVATIONS_SOURCE=target
# MARKETPLACE_DISCOVERY_SOURCE=target
# PMS_OPERATIONS_SOURCE=target
# FINANCE_SOURCE=target
# BOOKING_CHECKOUT_COMMAND_SOURCE=target
#
# For next-stack surfaces that are not available yet, set their source
# explicitly to disabled instead of relying on the local disabled default.
# MARKETPLACE_DISCOVERY_SOURCE=disabled
# PMS_OPERATIONS_SOURCE=disabled

# Ask Intelligence
# Fixture evidence stays the local/test default. Set target only when
# TARGET_DATABASE_URL points at the migrated target database.
# Fixture model mode is also the local/test default. Set OpenAI only for an
# environment that has the provider secret and model configured.
# ASK_INTELLIGENCE_PROVIDER=fixture
# ASK_INTELLIGENCE_PROVIDER=openai
# ASK_INTELLIGENCE_MODEL=gpt-5.5
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORGANIZATION=org_...
# OPENAI_PROJECT=proj_...
#
# Roll back OpenAI mode by setting ASK_INTELLIGENCE_PROVIDER=fixture or removing
# ASK_INTELLIGENCE_PROVIDER, ASK_INTELLIGENCE_MODEL, and OPENAI_* values.
# Deployment values are owned outside this repo by the platform task definition
# for next-target-backend; keep OPENAI_API_KEY in AWS SSM/Secrets Manager, not in
# GitHub Actions logs or committed env files.
# ASK_INTELLIGENCE_EVIDENCE_SOURCE=fixture
# ASK_INTELLIGENCE_EVIDENCE_SOURCE=target

# Platform media serving (VAY-821)
# Keep unset before media cutover. Production/staging values are provisioned in
# deployment secrets/task definitions, not committed here.
#
# Required as a complete set when platform media serving is activated:
# - PLATFORM_MEDIA_BUCKET: private platform media bucket for this environment.
# - PLATFORM_MEDIA_CDN_BASE_URL: public CDN HTTPS origin, no path/query.
# - PLATFORM_MEDIA_CDN_ORIGIN_HOST: private bucket origin host used by the CDN.
#
# Public URL shape:
#   {PLATFORM_MEDIA_CDN_BASE_URL}/{PLATFORM_MEDIA_PUBLIC_PATH_PREFIX}/{mediaId}/{variant}/{version}.{ext}
# Public URLs are immutable and cacheable; replacing media must mint a new media
# object or version URL instead of overwriting the old URL.
#
# Private media is never served from the public CDN path. Authorized downloads
# use short-lived signed object URLs or a platform endpoint that signs with the
# same TTL limits.
# PLATFORM_MEDIA_BUCKET=vayada-media-development
# PLATFORM_MEDIA_CDN_BASE_URL=https://cdn.dev.vayada.example
# PLATFORM_MEDIA_CDN_ORIGIN_HOST=vayada-media-development.s3.us-east-1.amazonaws.com
# PLATFORM_MEDIA_PUBLIC_PATH_PREFIX=media
# PLATFORM_MEDIA_PUBLIC_CACHE_CONTROL=public, max-age=31536000, immutable
# PLATFORM_MEDIA_PRIVATE_DOWNLOAD_TTL_SECONDS=300
# PLATFORM_MEDIA_PRIVATE_DOWNLOAD_MAX_TTL_SECONDS=900
