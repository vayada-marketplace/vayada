# Backend API URL
# This is the base URL for the backend API
# For local development, use: http://localhost:8000
# For production, use your production backend URL (e.g., https://api.vayada.com)
NEXT_PUBLIC_API_URL=http://localhost:8000

# PMS & Booking Engine URL
# Base URL of the separate PMS product, used by the product chooser page to
# deep-link to the PMS login (NEXT_PUBLIC_PMS_URL/login).
# For local development, use: http://localhost:3004
# For production, defaults to https://pms.vayada.com
NEXT_PUBLIC_PMS_URL=https://pms.vayada.com

# Booking Engine admin URL
# Base URL of the separate Booking Engine admin product. The marketplace
# sidebar's app switcher deep-links here via /handoff so hotel users can
# switch back to the Booking Engine without re-login.
# For local development, use: http://localhost:3003
# For production, defaults to https://admin.booking.vayada.com
NEXT_PUBLIC_BOOKING_ADMIN_URL=https://admin.booking.vayada.com

# Marketing site URL
# The public marketing site (home, product pages, pricing, about, contact,
# legal) is a separate deployment. This app links out to it for those pages.
# For local development, use: http://localhost:3006
# For production, defaults to https://vayada.com
NEXT_PUBLIC_MARKETING_URL=https://vayada.com

# Node Environment
# Set to 'development' for local development, 'production' for production builds
NODE_ENV=development
