# marketplace-api
# Code defaults to portless URL; set only to override.
#   portless default:  https://api.marketplace.localhost
#   plain-port dev:    http://localhost:8000
#   production:        https://api.vayada.com
# NEXT_PUBLIC_API_URL=

# apps/api platform media upload-session API
# Code defaults to portless apps/api URL; set only to override.
#   portless default:  https://api.localhost
#   plain-port dev:    http://localhost:8003
#   production:        https://api.vayada.com
# NEXT_PUBLIC_PLATFORM_MEDIA_API_URL=

# PMS frontend (deep-link target for the product chooser → PMS login)
# Default in code: https://pms.vayada.com (prod).
#   portless dev:      https://pms.localhost
#   plain-port dev:    http://localhost:3004
NEXT_PUBLIC_PMS_URL=https://pms.vayada.com

# Booking-admin frontend (sidebar app-switcher / handoff target)
# Default in code: https://admin.booking.vayada.com (prod).
#   portless dev:      https://admin.booking.localhost
#   plain-port dev:    http://localhost:3003
NEXT_PUBLIC_BOOKING_ADMIN_URL=https://admin.booking.vayada.com

# Marketing/landing site (out-links from this app)
# Default in code: https://vayada.com (prod).
#   portless dev:      https://landing.localhost
#   plain-port dev:    http://localhost:3006
NEXT_PUBLIC_MARKETING_URL=https://vayada.com

# Node Environment
# Set to 'development' for local development, 'production' for production builds
NODE_ENV=development
